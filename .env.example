DATABASE_URL=postgresql://user:password@localhost:5432/lingua
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Yandex Object Storage (S3 API). Secrets only on the server — never in the frontend.
# Console: Object Storage → Buckets (bucket name); IAM → Service accounts → Access keys (static key).
# If PutObject returns AccessDenied: grant the service account a role with write access to the bucket
# (e.g. storage.editor), not storage.viewer.
#
# Optional legacy names still supported: YC_S3_BUCKET, YC_S3_ACCESS_KEY_ID, YC_S3_SECRET_ACCESS_KEY,
# YC_S3_REGION, YC_S3_ENDPOINT, YC_S3_PUBLIC_BASE_URL.
YANDEX_STORAGE_REGION=ru-central1
YANDEX_STORAGE_ENDPOINT=https://storage.yandexcloud.net
# Bucket name only (no https://). If you paste a full object URL, only the bucket segment is used.
YANDEX_STORAGE_BUCKET=
YANDEX_STORAGE_ACCESS_KEY_ID=
YANDEX_STORAGE_SECRET_ACCESS_KEY=
# YANDEX_STORAGE_PUBLIC_BASE_URL=https://storage.yandexcloud.net/your-bucket-name

# Auth (JWT access + opaque refresh in httpOnly cookies; refresh row stored in refresh_tokens)
JWT_SECRET=change-this-to-a-long-random-string
# Short-lived access JWT (Authorization header or access_token cookie)
JWT_ACCESS_EXPIRES_IN=15m
# Refresh token TTL (DB + refresh_token cookie)
JWT_REFRESH_EXPIRES_IN=7d
# Cookie names (defaults: access_token, refresh_token)
# COOKIE_ACCESS_NAME=access_token
# COOKIE_REFRESH_NAME=refresh_token
# Production: set COOKIE_SECURE=true and same-site as needed
# COOKIE_SECURE=false
# COOKIE_SAME_SITE=lax
